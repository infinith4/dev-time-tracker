{
  "name": "@infinith4/cli-tracker",
  "version": "1.0.0",
  "description": "CLI time tracking tool",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/infinith4/dev-time-tracker.git",
    "directory": "cli-tracker"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "trc": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "cli",
    "timer",
    "time-tracking"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
